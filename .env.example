# n8n Environment Variables Template
# Copy this file to .env and customize the values

# Basic Authentication
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=your_workflow_username
N8N_BASIC_AUTH_PASSWORD=your_strong_password_here

# Security - Enable secure cookies for HTTPS
N8N_SECURE_COOKIE=true

# Reverse proxy / HTTPS settings
N8N_PROTOCOL=http
N8N_PORT=5678
N8N_HOST=0.0.0.0
WEBHOOK_URL=https://n8n-workflow.local/

# Database Configuration (SQLite is used by default)
# For PostgreSQL, uncomment and configure:
# DB_TYPE=postgresdb
# DB_POSTGRESDB_HOST=postgres
# DB_POSTGRESDB_PORT=5432
# DB_POSTGRESDB_DATABASE=n8n
# DB_POSTGRESDB_USER=n8n
# DB_POSTGRESDB_PASSWORD=your_secure_password